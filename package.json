{
  "name": "clawwatch",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infra403/clawwatch.git"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:dashboard": "pnpm --filter @clawwatch/dashboard build",
    "build:engine": "pnpm --filter @clawwatch/engine build",
    "dev:engine": "pnpm --filter @clawwatch/engine dev",
    "dev:dashboard": "pnpm --filter @clawwatch/dashboard dev",
    "test": "vitest run",
    "start": "node packages/engine/dist/index.js"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
