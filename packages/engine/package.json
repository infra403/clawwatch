{
  "name": "@clawwatch/engine",
  "version": "0.1.0",
  "type": "module",
  "description": "ClawWatch engine — AI Agent efficiency monitor analysis engine",
  "bin": {
    "clawwatch-engine": "./dist/index.js"
  },
  "files": ["dist", "package.json"],
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": {
      "import": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --banner.js '#!/usr/bin/env node'",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@clawwatch/shared": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^9.0.0",
    "better-sqlite3": "^11.0.0",
    "fastify": "^5.0.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0"
  }
}
