{
  "name": "@clawwatch/shared",
  "version": "0.1.0",
  "type": "module",
  "description": "ClawWatch shared types and utilities",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infra403/clawwatch.git",
    "directory": "packages/shared"
  },
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
