{
  "name": "@clawwatch/plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "ClawWatch OpenClaw plugin — AI Agent efficiency monitor",
  "openclaw": {
    "extensions": ["src/index.ts"]
  },
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./*": { "import": "./dist/*.js", "types": "./dist/*.d.ts" }
  },
  "files": ["dist", "openclaw.plugin.json", "package.json"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts"
  },
  "dependencies": {
    "@clawwatch/shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0"
  }
}
